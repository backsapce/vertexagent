{
  "name": "vertex-agent",
  "description": "AI agent running purely in the browser",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/agent.js\" \"vite\"",
    "dev:agent": "node server/agent.js",
    "dev:front": "vite",
    "build": "vite build",
    "build:pages": "cross-env VITE_BASE=/VertexAgent/ vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:docker": "docker buildx build --platform linux/amd64,linux/arm64 -t backsapce/vertex-agent:$(node -p \"require('./package.json').version\") --push ."
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.9",
    "e2b": "^2.19.0",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tokenlens": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  }
}
